# Copy to .env and fill in. Commit this example, NOT .env.
#
# Two tiers of config:
#   VITE_*  -> PUBLIC. Compiled into the browser bundle. Never put a billed
#              API key here — anyone can read it from the shipped JS.
#   others  -> SERVER ONLY. Read by the /api serverless functions. Set these in
#              the Vercel dashboard (Project → Settings → Environment Variables)
#              for production, and here for local `vercel dev`.

# --- Client (public) ---
VITE_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token
VITE_GOOGLE_PLACES_ENABLED=true   # feature flag only, no key
VITE_GEMINI_ENABLED=true          # shows the importer's "Clean up with AI" button

# --- Server only (the billed keys live here) ---
GOOGLE_PLACES_API_KEY=your_google_places_api_key
GEMINI_API_KEY=your_gemini_api_key
# Service-account JSON, single line, with private_key newlines escaped as \n.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}
